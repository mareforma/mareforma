{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mareforma",
  "colors": {
    "primary": "#c8965a",
    "light": "#d4a76a",
    "dark": "#8a6338"
  },
  "background": {
    "dark": "#0e0e0c"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Playfair Display",
      "weight": 700
    },
    "body": {
      "family": "Hanken Grotesk",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "styling": {
    "codeblocks": "dark"
  },
  "customCSS": "/style.css",
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://mareforma.com"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/mareforma/mareforma"
      }
    ],
    "primary": {
      "type": "button",
      "label": "AGENTS.md",
      "href": "/for-agents/agents"
    }
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction/why-mareforma",
              "introduction/quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/trust",
              "concepts/origin",
              "concepts/the-graph"
            ]
          },
          {
            "group": "For agents",
            "pages": [
              "for-agents/agents"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/api",
              "reference/data-model",
              "reference/cli",
              "reference/changelog"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/api-walkthrough",
              "examples/compounding-agents",
              "examples/documented-contestation",
              "examples/private-data-public-findings",
              "examples/drug-target-provenance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/mareforma/mareforma",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mareforma/mareforma"
    }
  }
}
